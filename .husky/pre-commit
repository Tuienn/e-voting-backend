#!/usr/bin/env sh

set -e

# Capture files that were staged when commit started.
STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

nx run-many -t lint
pnpm run format

# Re-stage only files that were already staged so formatter changes are included.
if [ -n "$STAGED_FILES" ]; then
	printf '%s\n' "$STAGED_FILES" | while IFS= read -r file; do
		git add -- "$file"
	done
fi