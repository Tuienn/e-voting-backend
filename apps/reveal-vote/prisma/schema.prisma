// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


type SignatureRevealedVote {
  h String
  sPrime String
}

model RevealedVote {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    electionId String   @db.ObjectId
    // Mảng ứng viên được chọn trong 1 lá phiếu (canonical: dedupe + sort). 1 ballot = 1 record.
    candidateIds String[] @db.ObjectId

    revealKey String
    // recovery: khi retry sau partial-fail (chain đã có revealKey nhưng DB chưa ghi),
    // GetUsedReveal KHÔNG trả txId nên blockchainRef có thể null cho record được phục hồi
    blockchainRef   String?
    signature SignatureRevealedVote
    revealedAt DateTime @default(now())

    @@index([electionId]) //lấy revealed votes của election X (tally per-candidate qua aggregateRaw $unwind)
    @@unique([electionId, revealKey]) //mỗi vote chỉ được reveal 1 lần cho 1 election
    @@unique([electionId, signature.h, signature.sPrime]) //mỗi vote chỉ được reveal 1 lần cho 1 election
    @@map("revealed_votes")
}
