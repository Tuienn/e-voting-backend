NODE_ENV=development
HTTP_PORT=3008
SERVICE_NAME=socket

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=secret

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8081

# --- mTLS (internal service) ---
# Bật ở production SAU KHI đã sinh cert (scripts/gen-mtls-certs.sh).
# Để false thì toàn bộ TCP/Redis chạy plaintext như cũ (phù hợp dev local).
MTLS_ENABLED=false
TLS_CA_PATH=./certs/ca.crt
TLS_CERT_PATH=./certs/socket.crt
TLS_KEY_PATH=./certs/socket.key
