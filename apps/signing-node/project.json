{
    "name": "signing-node",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/signing-node/src",
    "projectType": "application",
    "tags": [],
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "webpack-cli build",
                "args": ["--node-env=production"],
                "cwd": "apps/signing-node"
            },
            "configurations": {
                "development": {
                    "args": ["--node-env=development"]
                }
            }
        },
        "prune-lockfile": {
            "dependsOn": ["build"],
            "cache": true,
            "executor": "@nx/js:prune-lockfile",
            "outputs": [
                "{workspaceRoot}/dist/apps/signing-node/package.json",
                "{workspaceRoot}/dist/apps/signing-node/pnpm-lock.yaml"
            ],
            "options": {
                "buildTarget": "build"
            }
        },
        "copy-workspace-modules": {
            "dependsOn": ["build"],
            "cache": true,
            "outputs": ["{workspaceRoot}/dist/apps/signing-node/workspace_modules"],
            "executor": "@nx/js:copy-workspace-modules",
            "options": {
                "buildTarget": "build"
            }
        },
        "prune": {
            "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
            "executor": "nx:noop"
        },
        "build-watch": {
            "continuous": true,
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm exec webpack-cli build --watch --node-env=development",
                "cwd": "apps/signing-node",
                "readyWhen": "compiled successfully"
            }
        },
        "serve-node1": {
            "continuous": true,
            "executor": "nx:run-commands",
            "dependsOn": ["build-watch"],
            "defaultConfiguration": "development",
            "options": {
                "command": "node --watch --env-file=apps/signing-node/.node1.env.development dist/apps/signing-node/main.js",
                "cwd": "."
            },
            "configurations": {
                "development": {},
                "production": {
                    "command": "node --env-file=apps/signing-node/.node1.env.production dist/apps/signing-node/main.js"
                }
            }
        },
        "serve-node2": {
            "continuous": true,
            "executor": "nx:run-commands",
            "dependsOn": ["build-watch"],
            "defaultConfiguration": "development",
            "options": {
                "command": "node --watch --env-file=apps/signing-node/.node2.env.development dist/apps/signing-node/main.js",
                "cwd": "."
            },
            "configurations": {
                "development": {},
                "production": {
                    "command": "node --env-file=apps/signing-node/.node2.env.production dist/apps/signing-node/main.js"
                }
            }
        },
        "serve-node3": {
            "continuous": true,
            "executor": "nx:run-commands",
            "dependsOn": ["build-watch"],
            "defaultConfiguration": "development",
            "options": {
                "command": "node --watch --env-file=apps/signing-node/.node3.env.development dist/apps/signing-node/main.js",
                "cwd": "."
            },
            "configurations": {
                "development": {},
                "production": {
                    "command": "node --env-file=apps/signing-node/.node3.env.production dist/apps/signing-node/main.js"
                }
            }
        },
        "serve": {
            "continuous": true,
            "executor": "nx:run-commands",
            "dependsOn": ["serve-node1", "serve-node2", "serve-node3"],
            "options": {
                "command": "node -e \"process.stdin.resume()\"",
                "cwd": "."
            }
        },
        "test": {
            "options": {
                "passWithNoTests": true
            }
        }
    }
}
