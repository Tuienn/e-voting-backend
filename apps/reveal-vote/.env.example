NODE_ENV=development
HTTP_PORT=3007
HTTP_GLOBAL_PREFIX=api/v1
TCP_HOST=localhost
TCP_PORT=3307
SERVICE_NAME=REVEAL_VOTE

COORDINATOR_TCP_NAME=COORDINATOR
COORDINATOR_TCP_HOST=localhost
COORDINATOR_TCP_PORT=3303

IDENTITY_TCP_NAME=IDENTITY
IDENTITY_TCP_HOST=localhost
IDENTITY_TCP_PORT=3302

FABRIC_HOST=http://192.168.122.133:8100/api/v1
FABRIC_USERNAME=e-voting-client
FABRIC_PASSWORD=12345QTqt
FABRIC_CHAINCODE_ID=2
FABRIC_CHANNEL_NAME=votechannel
FABRIC_ORG_ID=3

# Rate Limiting: tối đa THROTTLE_LIMIT request mỗi THROTTLE_TTL milliseconds
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DATABASE_URL="mongodb://root:password@localhost:27017/revealVoteDb?authSource=admin&retryWrites=true&w=majority"

# --- mTLS (internal service) ---
# Bật ở production SAU KHI đã sinh cert (scripts/gen-mtls-certs.sh).
# Để false thì toàn bộ TCP/Redis chạy plaintext như cũ (phù hợp dev local).
MTLS_ENABLED=false
TLS_CA_PATH=./certs/ca.crt
TLS_CERT_PATH=./certs/reveal-vote.crt
TLS_KEY_PATH=./certs/reveal-vote.key
