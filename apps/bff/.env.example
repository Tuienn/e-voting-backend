NODE_ENV=development
HTTP_PORT=3001
HTTP_GLOBAL_PREFIX=api/v1
TCP_HOST=localhost
TCP_PORT=3301
SERVICE_NAME=BFF

IDENTITY_TCP_NAME=IDENTITY
IDENTITY_TCP_HOST=localhost
IDENTITY_TCP_PORT=3302

COORDINATOR_TCP_NAME=COORDINATOR
COORDINATOR_TCP_HOST=localhost
COORDINATOR_TCP_PORT=3303

# Rate Limiting: tối đa THROTTLE_LIMIT request mỗi THROTTLE_TTL milliseconds
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_WEB_ORIGIN=http://localhost:5173

JWT_ACCESS_SECRET=8e24WqYssEXRkCKVPXIOtuaWrsL3V1mcgKyyxJClfgc=

REDIS_CACHE_TTL=60000
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=secret

# --- mTLS (internal service) ---
# Bật ở production SAU KHI đã sinh cert (scripts/gen-mtls-certs.sh).
# Để false thì toàn bộ TCP/Redis chạy plaintext như cũ (phù hợp dev local).
MTLS_ENABLED=false
TLS_CA_PATH=./certs/ca.crt
TLS_CERT_PATH=./certs/bff.crt
TLS_KEY_PATH=./certs/bff.key
